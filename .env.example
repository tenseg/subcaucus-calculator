REACT_APP_VERSION=$npm_package_version
CLOUDFLARE_ACCOUNT_ID=___ # the account ID at cloudflare
CLOUDFLARE_WRANGLER_PROJECT="___" # the project slug at cloudflare
CLOUDFLARE_API_TOKEN=___ # or use 1Password CLI with wrangler
BROWSER=none # prevents CRA from opening the browser automatically if desired
PORT=3054 # set the port for development server